# Public API base (no trailing slash). Production: your Railway service URL.
# Example: https://your-service.up.railway.app
VITE_API_URL=http://localhost:8000

# Firebase (optional). From Firebase Console → Project settings → Your apps → Web app config.
# Enable Authentication → Sign-in method → Google. Add authorized domains (localhost, your Vercel domain).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional; enables Google Analytics in the web app when set.
VITE_FIREBASE_MEASUREMENT_ID=

# Dev only: when "true", Daily log shows a button that writes 14 days of demo data
# to Firestore for the signed-in user (users/{uid}/dailyLogs/{YYYY-MM-DD}).
VITE_ENABLE_LOG_SEED=false
